digraph "Object"
{
 // LATEX_PDF_SIZE
  bgcolor="transparent";
  edge [fontname=Helvetica,fontsize=10,labelfontname=Helvetica,labelfontsize=10];
  node [fontname=Helvetica,fontsize=10,shape=box,height=0.2,width=0.4];
  Node1 [label="Object",height=0.2,width=0.4,color="gray40", fillcolor="grey60", style="filled", fontcolor="black",tooltip=" "];
  Node1 -> Node2 [dir="back",color="steelblue1",style="solid"];
  Node2 [label="Vehicle",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$structVehicle.html",tooltip=" "];
  Node2 -> Node3 [dir="back",color="steelblue1",style="solid"];
  Node3 [label="Car",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$structCar.html",tooltip=" "];
  Node2 -> Node4 [dir="back",color="steelblue1",style="solid"];
  Node4 [label="Truck",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$structTruck.html",tooltip=" "];
}
